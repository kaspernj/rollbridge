{
  "name": "rollbridge",
  "version": "0.1.0",
  "description": "Zero-downtime process supervisor and local traffic switcher for deploy-managed apps.",
  "type": "module",
  "bin": {
    "rollbridge": "./bin/rollbridge"
  },
  "scripts": {
    "all-checks": "npm run typecheck && npm run lint && npm test",
    "lint": "eslint",
    "release:patch": "node scripts/release-patch.js",
    "test": "node --test test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "http-proxy": "^1.18.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
